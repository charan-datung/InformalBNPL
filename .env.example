# Copy this file to .env.local and fill in your Supabase project values.
# .env.local is gitignored — never commit real keys.

# Supabase project URL, e.g. https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase "anon" / publishable public key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role / secret key — SERVER ONLY. Bypasses Row Level Security.
# Used by the server-side mutation path (src/lib/supabase/admin.ts). Never
# expose this to the browser or import the admin client from a Client Component.
SUPABASE_SERVICE_ROLE_KEY=

# Optional. When set, server errors are forwarded to your error tracker (wire
# the forward in src/lib/observability/logger.ts). Leave blank for the pilot.
SENTRY_DSN=

# Transactional email (approval notices, etc.) via SMTP. Supabase sends the auth
# /confirmation emails separately; these power app-driven mail. Without SMTP_USER
# + SMTP_PASS, app emails are skipped (logged, never fatal).
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=sales@datung.io
SMTP_PASS=
EMAIL_FROM=Datung <sales@datung.io>

# Optional. Absolute app URL used for links/buttons in emails, e.g.
# https://app.datung.io  (no trailing slash).
NEXT_PUBLIC_APP_URL=

# Secret guarding the daily reminder cron (/api/cron/payment-reminders). Vercel
# Cron sends it as `Authorization: Bearer $CRON_SECRET`. Set this in Vercel; if
# unset, the cron endpoint refuses all requests (no reminders are sent).
CRON_SECRET=
